# ===========================================
# MNEMINE APPLICATION ENVIRONMENT VARIABLES
# ===========================================

# Application Environment
NODE_ENV=development

# Frontend Environment Variables (used during build)
VITE_BACKEND_URL=http://localhost:10112
VITE_WS_URL=ws://localhost:10112/ws
VITE_APP_NAME=Mnemine
VITE_APP_VERSION=1.0.0
# For Render deployment:
# VITE_API_URL=https://mnemine-backend.onrender.com

# Backend Environment Variables
PORT=10112
BACKEND_URL=http://localhost:10112
# For Render deployment:
# PORT=10000
# CORS_ORIGIN=https://mnemine-frontend.onrender.com

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhook/your_bot_token
WEBHOOK_DELAY_MS=0

# Database Configuration
# Development (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/mnemine_dev"
POSTGRES_DB=mnemine_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Production (PostgreSQL)
# DATABASE_URL="postgresql://username:password@localhost:5432/mnemine"
# POSTGRES_DB=mnemine
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_secure_password

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# Security Configuration
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
ENCRYPTION_KEY=your_encryption_key_here_32_characters
SESSION_SECRET=your_session_secret_here
ADMIN_TELEGRAM_ID=6760298907
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Security Headers
CSP_NONCE_ENABLED=true
CSP_REPORT_URI=https://yourdomain.com/csp-report

# Database Security
DB_SSL_MODE=require
DB_SSL_CA_PATH=/path/to/ca-cert.pem

# API Security
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_METRICS=true
PROMETHEUS_PORT=9090

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourdomain.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000

# Webhook Configuration
# WEBHOOK_DELAY_MS: Add delay to webhook processing (in milliseconds)
# Useful for rate limiting or testing webhook timeout scenarios
# Set to 0 for no delay, or specify delay in milliseconds (e.g., 1000 for 1 second)
# WEBHOOK_DELAY_MS=1000

# Production Environment Variables (uncomment for production)
# NODE_ENV=production
# VITE_BACKEND_URL=https://your-domain.com
# VITE_WS_URL=wss://your-domain.com/ws
# BACKEND_URL=https://your-domain.com
# DATABASE_URL="postgresql://username:password@postgres:5432/mnemine"
# REDIS_URL=redis://redis:6379

# Monitoring (optional)
# GRAFANA_PASSWORD=your_grafana_password
# PROMETHEUS_RETENTION_TIME=200h

# SSL Configuration (for production)
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
