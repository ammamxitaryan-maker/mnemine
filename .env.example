# --- Shared Environment Variables (for local development) ---
# These are examples. For Render, you will set them in the Render dashboard.

# Backend URL for client-side API calls (local development)
VITE_BACKEND_URL=http://localhost:10112

# WebSocket URL for client-side real-time connections (local development)
VITE_WS_URL=ws://localhost:10112/ws

# Application Name (for client)
VITE_APP_NAME=Mnemine

# --- Backend Environment Variables ---

# Node.js environment (development, production, test)
NODE_ENV=development

# Port for the backend server
PORT=10112

# Frontend URL (for CORS and Telegram Web App link)
FRONTEND_URL=http://localhost:5173

# Backend URL (for Telegram Webhook and internal references)
BACKEND_URL=http://localhost:10112

# Database connection string (PostgreSQL for production, SQLite for local dev)
# Example for SQLite: DATABASE_URL="file:./dev.db"
# Example for PostgreSQL: DATABASE_URL="postgresql://user:password@host:port/database"
DATABASE_URL="file:./server/prisma/dev.db"

# Telegram Bot Token (REQUIRED for bot functionality)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Webhook URL (REQUIRED for bot in production, usually same as BACKEND_URL/webhook)
# For local development, you might not set a webhook or use ngrok
TELEGRAM_WEBHOOK_URL=http://localhost:10112/webhook

# Admin Telegram ID (for granting admin privileges)
ADMIN_TELEGRAM_ID=your_telegram_user_id

# JWT Secret for authentication (min 32 characters, generate a strong one!)
JWT_SECRET=your_32_character_jwt_secret_here

# Encryption Key (for sensitive data, 32 characters for AES-256)
ENCRYPTION_KEY=your_32_character_encryption_key

# Session Secret (for session management)
SESSION_SECRET=your_session_secret_here

# Allowed origins for CORS (comma-separated for multiple)
# For Render, this will be your frontend service URL
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate Limiting settings (optional)
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# Logging level (info, warn, error, debug)
LOG_LEVEL=info

# Mock Telegram Init Data for local development (if not running in Telegram WebApp)
# VITE_MOCK_TELEGRAM_INIT_DATA='user=%7B%22id%22%3A123456789%2C%22first_name%22%3A%22Test%22%2C%22last_name%22%3A%22User%22%2C%22username%22%3A%22testuser%22%2C%22language_code%22%3A%22en%22%7D&chat_instance=-123456789&chat_type=sender&auth_date=1234567890&hash=test_hash'