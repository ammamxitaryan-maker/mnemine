# Production Environment Variables
# Copy this file to .env and update values for production

# Node Environment
NODE_ENV=production

# Database Configuration
DATABASE_URL=file:./prisma/prod.db

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-32-characters-minimum
ENCRYPTION_KEY=your-32-character-encryption-key-here
SESSION_SECRET=your-session-secret-for-production

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ADMIN_TELEGRAM_ID=6760298907
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhook/your-bot-token

# Server Configuration
PORT=10112
BACKEND_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# Webhook Configuration
WEBHOOK_DELAY_MS=0

# API Configuration
API_KEY=your-api-key-for-external-services

# Logging Configuration
LOG_LEVEL=info

# Security Configuration
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
TRUST_PROXY=true

# Performance Configuration
COMPRESSION_ENABLED=true
CACHE_ENABLED=true
CACHE_TTL=300000
