{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --config vite.config.prod.ts",
    "build:debug": "vite build --config vite.config.simple.ts",
    "build:simple": "node scripts/create-simple-build.js create && vite build --config vite.config.simple.ts && node scripts/create-simple-build.js restore",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:check": "eslint . --ext ts,tsx --max-warnings 0",
    "clean": "rm -rf dist node_modules/.vite",
    "prebuild": "npm run type-check && npm run lint:check",
    "postbuild": "echo 'Build completed successfully!'",
    "precommit": "npm run lint:check && npm run type-check && npm run test",
    "validate": "npm run lint:check && npm run type-check",
    "analyze": "npm run build:analyze && npx vite-bundle-analyzer dist/stats.html"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
