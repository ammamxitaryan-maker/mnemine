{
  "name": "server",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma db push --accept-data-loss && tsc-watch --onSuccess \"node dist/index.js\"",
    "build": "npx prisma generate && tsc && pnpm run postbuild",
    "postbuild": "node -e \"const fs = require('fs'); if (!fs.existsSync('dist')) fs.mkdirSync('dist'); fs.copyFileSync('dist-package.json', 'dist/package.json');\"",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "shared": "workspace:*",
    "@prisma/client": "^6.16.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.5.5",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.3.1",
    "prisma": "^6.16.1",
    "supertest": "^7.0.0",
    "tsc-watch": "^6.2.0",
    "typescript": "^5.5.3",
    "vitest": "^1.3.1"
  }
}