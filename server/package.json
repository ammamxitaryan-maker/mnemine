{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "prisma db push && tsc-watch --onSuccess \"node dist/index.js\"",
    "build": "rm -rf dist && prisma generate && tsc && pnpm run postbuild",
    "build:prod": "rm -rf dist && prisma generate && tsc && pnpm run postbuild",
    "postbuild": "node -e \"const fs = require('fs'); if (!fs.existsSync('dist')) fs.mkdirSync('dist'); fs.copyFileSync('dist-package.json', 'dist/package.json');\"",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:generate:local": "prisma generate",
    "prisma:generate:prod": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:push:local": "prisma db push",
    "prisma:push:prod": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:local": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf dist",
    "precommit": "npm run type-check && npm run test",
    "validate": "npm run type-check"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.10",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^6.16.1",
    "telegraf": "^4.16.3",
    "typescript": "^5.7.2",
    "ws": "^8.18.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "supertest": "^7.0.0",
    "tsc-watch": "^6.2.0",
    "vitest": "^2.1.8"
  }
}