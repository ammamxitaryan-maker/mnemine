{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["./node_modules/.prisma/client"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "../shared/**/*.ts", "./node_modules/.prisma/client/index.d.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/test/**/*"]
}